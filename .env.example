# Copy to `.env` for local dev. On Railway, set these in Project → Variables.

# Optional — persistent disk for bot JSON + orders + receipts (Railway: mount volume, set to mount path e.g. /data)
# DATA_DIR=

# Required — Kinguin store API (product search, catalog)
KINGUIN_API_KEY=

# Catalog source switch is stored in DATA_DIR/catalog-provider.json (default: kinguin).
# Plati listing uses public search; product pages use Digiseller JSON (no key required for public goods).
# PLATI_SEARCH_URL=https://plati.io/api/search.ashx
# PLATI_DEFAULT_SEARCH_QUERY=steam
# DIGISELLER_API_BASE_URL=https://api.digiseller.com
# Optional Digiseller token for extra owner-only fields on product detail
# DIGISELLER_API_TOKEN=

# Optional — Telegram bot (admin notifications / commands)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated numeric user IDs
TELEGRAM_ADMIN_IDS=
