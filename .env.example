# =============================================================================
# GTX — نموذج متغيرات البيئة | Environment template
# انسخ إلى `.env` للتطوير المحلي. على Railway/Vercel انسخ القيم إلى لوحة Variables.
# لا تضع أسراراً حقيقية في هذا الملف ثم ترفعه إلى Git (يُستثنى `.env` لكن هذا الملف يُرجَع).
# =============================================================================

# -----------------------------------------------------------------------------
# 1) قاعدة البيانات | DATABASE_URL
# -----------------------------------------------------------------------------
# رابط اتصال PostgreSQL (مثلاً Neon). يُستخدم إن وُجدت ميزات تخزين/طلبات تحتاج DB.
# مثال: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# 2) مسار بيانات التطبيق على القرص | DATA_DIR (اختياري)
# -----------------------------------------------------------------------------
# مجلد لملفات JSON: مزود الكتالوج، إعدادات الترجمة، طلبات/إيصالات البوت، إلخ.
# على Railway: اربط Volume واضبط المسار، مثال: /data
# DATA_DIR=

# -----------------------------------------------------------------------------
# 3) متجر Kinguin | KINGUIN_API_KEY (مطلوب لمسار Kinguin)
# -----------------------------------------------------------------------------
# مفتاح واجهة Kinguin eCommerce API — سيرفر فقط.
# لوحة المطورين: https://www.kinguin.net/dev-portal
KINGUIN_API_KEY=

# -----------------------------------------------------------------------------
# 4) Cron محمي | CRON_SECRET (اختياري)
# -----------------------------------------------------------------------------
# لحماية مسارات cron مثل `/api/cron/sync-kinguin`: أرسل الهيدر
#   Authorization: Bearer <نفس_قيمة_CRON_SECRET>
CRON_SECRET=

# -----------------------------------------------------------------------------
# 5) بوت Telegram | TELEGRAM_* (اختياري)
# -----------------------------------------------------------------------------
# رمز البوت من @BotFather. معرف المحادثة للإشعارات. معرفات المشرفين مفصولة بفاصلة.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_IDS=

# -----------------------------------------------------------------------------
# 6) Google Custom Search — «هل تقصد؟» في البحث | GOOGLE_CUSTOM_* (اختياري)
# -----------------------------------------------------------------------------
# يقوّي اقتراحات التصحيح عند عدم وجود نتائج في الكتالوج.
# فعّل Custom Search JSON API في GCP وأنشئ محرك بحث (cx).
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# -----------------------------------------------------------------------------
# 6.1) بريد تسليم الطلب (اختياري لكنه مهم) | RESEND_*
# -----------------------------------------------------------------------------
# يُستخدم عند تنفيذ أمر البوت:
#   /deliver ORDER_ID تفاصيل التسليم
# لإرسال بريد "تم التسليم" مع رابط متابعة الطلب.
RESEND_API_KEY=
# مثال: GTX Gaming <orders@your-domain.com>
ORDER_EMAIL_FROM=

# -----------------------------------------------------------------------------
# 7) Auth.js / تسجيل الدخول بـ Google | AUTH_*
# -----------------------------------------------------------------------------
# AUTH_SECRET: عشوائي طويل لتشفير جلسة Auth.js — ليس نفس «Client secret» من Google.
#   توليد: npx auth secret   أو   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AUTH_URL: أصل الموقع بدون شرطة أخيرة (مثال محلي http://localhost:3000 ، إنتاج https://your-domain.com).
#   إن ظهرت Google Error 400: redirect_uri_mismatch: أضف في Google Console تحت Authorized redirect URIs
#   العنوان نفسه الذي يستخدمه المتصفح + المسار /api/auth/callback/google
#   (غالباً http://localhost:3000/api/auth/callback/google). إن فتحت الموقع بـ 127.0.0.1 أضف URI ثانياً بنفس الصيغة.
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: من Google Cloud Console → APIs & Services → Credentials
#   OAuth client نوع Web. أضف Redirect URI:
#   https://<نطاقك>/api/auth/callback/google
#   ومحلياً: http://localhost:3000/api/auth/callback/google
# إن ظهرت رسالة «لا يتوافق مع سياسة OAuth» مع Request details فيها redirect_uri صحيح:
#   - تأكد أن نوع العميل OAuth هو **Web application** (ليس Desktop/iOS).
#   - APIs & Services → OAuth consent screen: إن كان الوضع **Testing** أضف بريدك (حساب Google الذي تسجّل به)
#     ضمن **Test users**. بدون ذلك لا يُسمح بتسجيل الدخول إلا للحسابات المدرجة.
#   - Authorized JavaScript origins: http://localhost:3000 (و 127.0.0.1 إن استخدمته).
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# 8) Cloudflare Turnstile — حماية من الروبوتات | TURNSTILE_* (اختياري)
# -----------------------------------------------------------------------------
# من لوحة Cloudflare → Turnstile. إذا عيّنت NEXT_PUBLIC_TURNSTILE_SITE_KEY فعادةً
# يجب تعيين TURNSTILE_SECRET_KEY للتحقق من الخادم.
# بدون السر، واجهة التحقق تُتخطى في التطوير (راجع src/app/api/turnstile/verify).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# 9) إعدادات أخرى (ليست متغيرات بيئة — ملفات على القرص)
# -----------------------------------------------------------------------------
# - مزود الكتالوج (Kinguin/Plati): DATA_DIR/catalog-provider.json (أو الافتراضي kinguin).
# - ترجمة البحث العربي + MyMemory: DATA_DIR/search-translate.json (أو Telegram /searchtranslate).
