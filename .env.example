# Copy to `.env` for local dev. On Railway, set these in Project → Variables.

# Optional — persistent disk for bot JSON + orders + receipts (Railway: mount volume, set to mount path e.g. /data)
# DATA_DIR=

# Required — Kinguin store API (product search, catalog)
KINGUIN_API_KEY=

# Catalog source switch is stored in DATA_DIR/catalog-provider.json (default: kinguin).
# Plati search + Digiseller URLs are fixed in code (public endpoints).

# Optional — Telegram bot (admin notifications / commands)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated numeric user IDs
TELEGRAM_ADMIN_IDS=
