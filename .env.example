# =============================================================================
# First run (تشغيل المشروع لأول مرة)
# =============================================================================
# 1) npm install
# 2) npm run setup:env     → ينشئ ملف .env من هذا الملف إن لم يكن موجوداً
# 3) ضع مفتاح Kinguin في KINGUIN_API_KEY أدناه (مطلوب للمتجر والبحث)
# 4) npm run dev          → http://localhost:3000
# =============================================================================

# --- Required — Kinguin (catalog, search, product pages)
# https://www.kinguin.net/dev-portal
KINGUIN_API_KEY=

# --- Optional — persistent data (bot JSON, orders, receipts). Railway: mount volume
# DATA_DIR=

# --- Optional — Plati affiliate XML → /api/plati/goods
PLATI_GUID_AGENT=
PLATI_DEFAULT_SECTION_ID=

# --- Optional — Digiseller seller API → /api/digiseller/balance, /api/digiseller/currency
DIGISELLER_SELLER_ID=
DIGISELLER_API_GUID=
# If set: send Authorization: Bearer <value> or ?secret= on /api/digiseller/*
DIGISELLER_PROXY_SECRET=

# --- Optional — Telegram bot / webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_IDS=
